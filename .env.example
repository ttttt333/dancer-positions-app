# Supabase 連携（VITE_ はビルドに埋まる。Vercel では Project Settings > Environment Variables に同じキーで登録し再デプロイ）
# Dashboard: https://supabase.com  → プロジェクト → Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 従来の Express + SQLite API を使う場合（Vite 開発: 相対 /api ＝プロシー）
# VITE_SUPABASE_* が未設定のとき、または併用しないとき
# VITE_API_BASE_URL=

# 共同編集用 WebSocket（任意）
# VITE_COLLAB_WS=
