{
  "name": "dancer-positions-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently -k -n api,vite \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --force",
    "dev:vite": "vite --force --open",
    "dev:server": "node server/index.mjs",
    "build": "vite build",
    "type-check": "tsc -b",
    "start:prod": "node server/index.mjs",
    "lint": "eslint .",
    "preview": "vite preview --host --open",
    "open:app": "node scripts/open-app.mjs",
    "open:prod": "OPEN_URL=http://127.0.0.1:3001/ node scripts/open-app.mjs"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@react-three/fiber": "^9.6.0",
    "@supabase/supabase-js": "^2.105.1",
    "html-to-image": "^1.11.13",
    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.6.0",
    "three": "^0.183.2",
    "xlsx": "^0.18.5",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
